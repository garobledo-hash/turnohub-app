# ============================================================
# TurnoHub SaaS V2 — frontend env (Vite)
# Copy to `.env` for local dev. Set the same vars on Netlify.
# ============================================================

# Supabase (required)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Supabase Edge Functions base URL
# Format: https://<project-ref>.functions.supabase.co
VITE_FUNCTIONS_URL=https://YOUR-PROJECT.functions.supabase.co

# Public app URL (used by MP back_urls, also informational on the client)
VITE_APP_URL=https://your-app.netlify.app

# Optional: Mercado Pago public key (only if you embed Brick/Wallet on the client)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx

# ============================================================
# Supabase Edge Function secrets (NEVER expose to the frontend)
# Set with:  supabase secrets set KEY=value
# ------------------------------------------------------------
# MP_ACCESS_TOKEN=APP_USR-...        # or TEST-... for sandbox
# APP_URL=https://your-app.netlify.app
# FUNCTIONS_URL=https://YOUR-PROJECT.functions.supabase.co
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically)
# ============================================================
